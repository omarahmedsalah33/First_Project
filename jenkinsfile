pipeline {
    agent any

    tools {
        nodejs "NodeJS" // make sure NodeJS is installed in Jenkins with this name
    }

    stages {
        stage('Build App') {
            steps {
                script {
                    def gv = load('script.groovy')  // load from workspace root
                    dir('app') {                     // run npm inside app folder
                        gv.buildapp()
                    }
                }
            }
        }

        stage('Build Docker Image') {
            steps {
                script {
                    def gv = load('script.groovy')
                    gv.buildimage()
                }
            }
        }

        stage('Deploy App') {
            steps {
                script {
                    def gv = load('script.groovy')
                    gv.deployingapp()
                }
            }
        }
    }

    post {
        success {
            echo 'Pipeline finished successfully!'
        }
        failure {
            echo 'Pipeline failed. Check logs.'
        }
    }
}
