@Library('jenkins-shared-library') _
pipeline {
    agent any

    tools {
        nodejs "NodeJS" // make sure NodeJS is installed in Jenkins with this name
    }

    stages {
        stage('Build App') {
            steps {
                script {
                     Builapp()
                    }
                }
            }
        }

        stage('Build Docker Image') {
            steps {
                script {
                    Buildimage "omarsalah123/learningrepo:v1.0"
                }
            }
        }

    }

    post {
        success {
            echo 'Pipeline finished successfully!'
        }
        failure {
            echo 'Pipeline failed. Check logs.'
        }
    }
}
