pipeline {
    agent any

    stages {
        stage('Build App') {
            steps {
                node {
                    // Load your external Groovy script
                    def gv = load('script.groovy')
                    gv.buildingapp()
                }
            }
        }

        stage('Run Tests') {
            steps {
                node {
                    def gv = load('script.groovy')
                    gv.testingapp()
                }
            }
        }

        stage('Build Docker Image') {
            steps {
                node {
                    def gv = load('script.groovy')
                    gv.buildingimage()
                }
            }
        }

        stage('Deploy App') {
            steps {
                node {
                    def gv = load('script.groovy')
                    gv.deployingapp()
                }
            }
        }
    }
}
