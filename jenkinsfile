pipeline {
    agent any

    tools {
        nodejs "NodeJS" 
    }
    stages {
        stage('Build App') {
            steps {
                dir('app') {
                    script {
                        def gv = load('../script.groovy')
                        gv.buildapp()
                    }
                }
            }
        }    
        }

        stage('Build Docker Image') {
            steps {
                script {
                    def gv = load('../script.groovy')
                    gv.buildimage()
                }
            }
        }

        stage('Deploy App') {
            steps {
                script {
                    def gv = load('../script.groovy')
                    gv.deployingapp()
                }
            }
        }
    }

    post {
        success {
            echo 'Pipeline finished successfully!'
        }
        failure {
            echo 'Pipeline failed. Check logs.'
        }
    }
}
