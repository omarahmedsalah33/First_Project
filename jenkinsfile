@Library('jenkins-shared-library') _
pipeline {
    agent any
    tools {
        nodejs "NodeJS"
    }
    stages {
        stage('Build App') {
            steps {
                script {
                    Buildapp()
                }
            }
        }
        stage('Build Docker Image') {
            steps {
                script {
                    BuildImage('omarsalah123/learningrepo:v1.0')
                }
            }
        }
    }
    post {
        success {
            echo 'Pipeline finished successfully!'
        }
        failure {
            echo 'Pipeline failed. Check logs.'
        }
    }
}
