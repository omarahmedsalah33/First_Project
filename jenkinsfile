pipeline {
    agent any
    tools {
       nodejs 'NodeJS'
}
    stages {

        stage('Build App') {
            steps {
                script {
                    def gv = load('script.groovy')
                    gv.buildapp()
                }
            }
        }

        stage('Run Tests') {
            steps {
                script {
                    def gv = load('script.groovy')
                    gv.testingapp()
                }
            }
        }

        stage('Build Docker Image') {
            steps {
                script {
                    def gv = load('script.groovy')
                    gv.buildimage()
                }
            }
        }

        stage('Deploy App') {
            steps {
                script {
                    def gv = load('script.groovy')
                    gv.deployingapp()
                }
            }
        }
    }
}
