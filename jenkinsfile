pipeline {
    agent any

    tools {
        nodejs 'NodeJS'
    }

    environment {
        DOCKER_CREDENTIALS = 'docker_credentials'
        DOCKER_IMAGE = 'omarsalah123/learningrepo:v1.0'
    }

    stages {
        stage('Build App') {
            steps {
                node {
                    dir('app') {
                        script {
                            def gv = load('../script.groovy') // load your groovy script from root
                            gv.buildapp()
                        }
                    }
                }
            }
        }

        stage('Run Tests') {
            steps {
                node {
                    dir('app') {
                        script {
                            def gv = load('../script.groovy')
                            gv.testingapp()
                        }
                    }
                }
            }
        }

        stage('Build Docker Image') {
            steps {
                node {
                    script {
                        def gv = load('../script.groovy')
                        gv.buildimage()
                    }
                }
            }
        }

        stage('Deploy App') {
            steps {
                node {
                    script {
                        def gv = load('../script.groovy')
                        gv.deployingapp()
                    }
                }
            }
        }
    }

    post {
        success {
            echo 'Pipeline finished successfully!'
        }
        failure {
            echo 'Pipeline failed. Check logs.'
        }
    }
}
