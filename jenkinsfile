// Load your external Groovy script
def gv = load('script.groovy')

pipeline {
    agent any
    tools {
        nodejs 'NodeJs25.9.0'
    }

    stages {
        stage('Build App') {
            steps {
                script {
                    gv.buildingapp()
                }
            }
        }

        stage('Run Tests') {
            steps {
                script {
                    gv.testingapp()
                }
            }
        }

        stage('Build Docker Image') {
            steps {
                script {
                    gv.buildingimage()
                }
            }
        }

        stage('Deploy App') {
            steps {
                script {
                    gv.deployingapp()
                }
            }
        }
    }
}
